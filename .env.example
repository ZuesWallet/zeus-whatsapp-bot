# Service
PORT=3001
NODE_ENV=development

# Public URL — the externally reachable URL for this service
# Used to construct the Twilio webhook signature verification URL
# For local dev: use ngrok → https://abc123.ngrok.io
PUBLIC_URL=

# ZeusPay backend API — internal URL of the backend service
ZEUSPAY_API_URL=http://localhost:3000

# Redis — must point to the same Redis instance as the backend
# Shared for session storage and routing cache
REDIS_URL=redis://localhost:6379

# Encryption key — MUST match backend WALLET_ENCRYPTION_KEY exactly
# Used to decrypt partner BSP (Twilio) credentials stored encrypted in WhatsAppConfig
# 64 hex characters (32 bytes) — same AES-256-GCM key as backend
ENCRYPTION_KEY=

# Twilio master account credentials (ZeusPay's own Twilio account)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Internal service secret — shared between backend and this service
# Backend sends this header (X-Service-Secret) when calling /internal/*
# Generate with: openssl rand -hex 32
SERVICE_SECRET=

# Meta Cloud API credentials (only required for META_CLOUD BSP partners)
META_ACCESS_TOKEN=        # System user permanent token from Meta Developer App
META_PHONE_NUMBER_ID=     # Phone Number ID from WhatsApp > API Setup in developer portal
META_WABA_ID=             # WhatsApp Business Account ID
META_WEBHOOK_VERIFY_TOKEN= # Random string set when registering the webhook in the portal
META_APP_SECRET=           # App Secret from App Settings > Basic in developer portal
META_FLOW_ID=              # Flow ID from WhatsApp > Flows in developer portal

# WhatsApp Flow endpoint encryption key
# RSA 2048-bit private key (PEM format) — the matching public key must be uploaded
# to the Flow settings in Meta's developer portal under "Endpoint" configuration.
# Generate with: openssl genrsa -out flow_private.pem 2048
# Extract public key: openssl rsa -in flow_private.pem -pubout -out flow_public.pem
# Set this env var to the full PEM content (newlines as \n or use multiline syntax)
FLOW_PRIVATE_KEY=
