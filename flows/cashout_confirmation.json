{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "CONFIRM_CASHOUT": ["CASHOUT_SUCCESS", "CASHOUT_FAILED"],
    "CASHOUT_SUCCESS": [],
    "CASHOUT_FAILED": []
  },
  "screens": [
    {
      "id": "CONFIRM_CASHOUT",
      "title": "Confirm Cashout",
      "data": {
        "selling_text":   { "type": "string", "__example__": "Selling: 1 USDC" },
        "receive_text":   { "type": "string", "__example__": "You receive: ₦1,344.73" },
        "fee_text":       { "type": "string", "__example__": "Fee: ₦20.48" },
        "rate_text":      { "type": "string", "__example__": "Rate: 1 USDC = ₦1,365.21" },
        "bank_text":      { "type": "string", "__example__": "OPay — ••••8193" },
        "account_name":   { "type": "string", "__example__": "JOHN DOE" },
        "transaction_id": { "type": "string", "__example__": "txn_abc123" },
        "error_message":  { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Transaction Summary" },
          { "type": "TextBody", "text": "${data.selling_text}" },
          { "type": "TextBody", "text": "${data.receive_text}" },
          { "type": "TextBody", "text": "${data.fee_text}" },
          { "type": "TextBody", "text": "${data.rate_text}" },
          { "type": "TextSubheading", "text": "Sending to" },
          { "type": "TextBody", "text": "${data.bank_text}" },
          { "type": "TextBody", "text": "${data.account_name}" },
          {
            "type": "TextInput",
            "label": "Transaction PIN",
            "name": "pin",
            "input-type": "password",
            "required": true,
            "min-chars": 6,
            "max-chars": 6,
            "helper-text": "Enter your 6-digit PIN",
            "error-message": "${data.error_message}"
          },
          {
            "type": "Footer",
            "label": "Confirm & Send",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "pin": "${form.pin}",
                "transaction_id": "${data.transaction_id}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "CASHOUT_SUCCESS",
      "title": "Transfer Submitted",
      "terminal": true,
      "success": true,
      "data": {
        "summary_text": { "type": "string", "__example__": "₦1,344.73 is on its way to your GTBank account ending in ••••6789." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Transfer Submitted! 🎉" },
          { "type": "TextBody", "text": "${data.summary_text}" },
          { "type": "TextBody", "text": "You'll be notified once the transfer is complete. This usually takes a few minutes." },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": { "status": "success" }
            }
          }
        ]
      }
    },
    {
      "id": "CASHOUT_FAILED",
      "title": "Transfer Failed",
      "terminal": true,
      "success": false,
      "data": {
        "error_message": { "type": "string", "__example__": "Your transfer could not be processed." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Transfer Failed ❌" },
          { "type": "TextBody", "text": "${data.error_message}" },
          { "type": "TextBody", "text": "Your wallet balance has been refunded. Please try again in a few minutes by typing /withdraw." },
          {
            "type": "Footer",
            "label": "Close",
            "on-click-action": {
              "name": "complete",
              "payload": { "status": "failed" }
            }
          }
        ]
      }
    }
  ]
}
