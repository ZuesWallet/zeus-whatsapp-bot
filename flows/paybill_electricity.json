{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "ENTER_METER": ["CONFIRM_AMOUNT"],
    "CONFIRM_AMOUNT": ["CONFIRM_PAYMENT"],
    "CONFIRM_PAYMENT": ["SUCCESS"],
    "SUCCESS": []
  },
  "screens": [
    {
      "id": "ENTER_METER",
      "title": "Enter Meter Number",
      "data": {
        "heading_text": { "type": "string", "__example__": "Pay Ikeja Electric" },
        "error_message": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "${data.heading_text}" },
          { "type": "TextBody", "text": "Enter your prepaid meter number." },
          {
            "type": "TextInput",
            "label": "Meter Number",
            "name": "meter_number",
            "input-type": "number",
            "required": true,
            "min-chars": 10,
            "max-chars": 13,
            "error-message": "${data.error_message}"
          },
          {
            "type": "Footer",
            "label": "Validate",
            "on-click-action": {
              "name": "data_exchange",
              "payload": { "meter_number": "${form.meter_number}" }
            }
          }
        ]
      }
    },
    {
      "id": "CONFIRM_AMOUNT",
      "title": "Confirm Meter",
      "data": {
        "verification_text": { "type": "string", "__example__": "JOHN DOE\nIkeja Electric — 04123456789" },
        "error_message": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Meter Verified" },
          { "type": "TextBody", "text": "${data.verification_text}" },
          { "type": "TextSubheading", "text": "How much would you like to pay?" },
          {
            "type": "TextInput",
            "label": "Amount (NGN)",
            "name": "amount_ngn",
            "input-type": "number",
            "required": true,
            "helper-text": "Min ₦100, Max ₦500,000",
            "error-message": "${data.error_message}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": { "amount_ngn": "${form.amount_ngn}" }
            }
          }
        ]
      }
    },
    {
      "id": "CONFIRM_PAYMENT",
      "title": "Confirm Payment",
      "data": {
        "summary_text": { "type": "string", "__example__": "Ikeja Electric — 04123456789\nJOHN DOE" },
        "amount_text": { "type": "string", "__example__": "Amount: ₦5,000" },
        "payment_text": { "type": "string", "__example__": "You pay: 3.75 USDT  •  Fee: ₦75" },
        "rate_text": { "type": "string", "__example__": "Rate: 1 USDT = ₦1,350" },
        "transaction_id": { "type": "string", "__example__": "txn_abc" },
        "error_message": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Confirm Payment" },
          { "type": "TextBody", "text": "${data.summary_text}" },
          { "type": "TextBody", "text": "${data.amount_text}" },
          { "type": "TextBody", "text": "${data.payment_text}" },
          { "type": "TextBody", "text": "${data.rate_text}" },
          {
            "type": "TextInput",
            "label": "Transaction PIN",
            "name": "pin",
            "input-type": "password",
            "required": true,
            "min-chars": 6,
            "max-chars": 6,
            "helper-text": "Enter your 6-digit PIN to confirm",
            "error-message": "${data.error_message}"
          },
          {
            "type": "Footer",
            "label": "Pay Now",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "pin": "${form.pin}",
                "transaction_id": "${data.transaction_id}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Payment Complete",
      "terminal": true,
      "success": true,
      "data": {
        "success_text": { "type": "string", "__example__": "₦5,000 sent to meter 04123456789." },
        "token_text": { "type": "string", "__example__": "Your token: 1234-5678-9012-3456" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Payment Successful" },
          { "type": "TextBody", "text": "${data.success_text}" },
          { "type": "TextBody", "text": "${data.token_text}" },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": { "name": "complete", "payload": { "status": "success" } }
          }
        ]
      }
    }
  ]
}
